# Database (DigitalOcean Managed PostgreSQL)
# Copie a connection string do painel do DO (inclui ?sslmode=require)
DATABASE_URL="postgresql://user:password@host:25060/defaultdb?sslmode=require"

# JWT
JWT_SECRET="troque-por-uma-string-aleatoria-longa"

# Anthropic (Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# DigitalOcean Spaces (S3-compatible)
SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
SPACES_REGION="nyc3"
SPACES_BUCKET="diagnostico-financeiro"
SPACES_KEY="seu-spaces-access-key"
SPACES_SECRET="seu-spaces-secret"

# CORS — URL do frontend no ar
FRONTEND_URL="https://seu-app.ondigitalocean.app"

# Porta local para dev
PORT=3001
